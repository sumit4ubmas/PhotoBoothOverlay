<?xml version="1.0" encoding="utf-8"?>
<!--
  This layout is inflated by OverlayService and drawn directly onto the
  WindowManager at TYPE_APPLICATION_OVERLAY — it appears on top of every app.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!--
      Semi-transparent background pill that holds the camera button.
      The whole FrameLayout is the drag + tap target.
    -->
    <ImageButton
        android:id="@+id/overlayFab"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@android:drawable/ic_menu_camera"
        android:background="@drawable/fab_background"
        android:padding="14dp"
        android:elevation="8dp"
        android:contentDescription="Launch Photo Booth"
        android:scaleType="fitCenter"
        android:tint="#ffffff" />

</FrameLayout>
